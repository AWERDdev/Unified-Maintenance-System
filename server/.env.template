# Rate Limiting Configuration (Values in Milliseconds)
# 1 minute = 60000 | 5 minutes = 300000 | 15 minutes = 900000

# High Security / Auth Limiter
AUTH_WINDOW_MS=300000     # 5 minutes for dev (change to 900000 / 15m in prod)
AUTH_MAX_REQUESTS=100     # Generous for testing (change to 5 or 10 in prod)

# General / Global Limiter
GEN_WINDOW_MS=300000      # 5 minutes window
GEN_MAX_REQUESTS=500      # Very high for dev so your frontend never gets blocked